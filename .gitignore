# --- secrets: NEVER commit ---
dashboard/.claude-token
dashboard/.gemini-key

# --- personal data: your Store is yours, not the app's ---
store/ideas/*
store/projects/*
store/tasks/*
store/sessions/*
!store/README.md

# --- runtime state ---
dashboard/chats/
dashboard/attachments/
dashboard/config.json
dashboard/notified.json

# --- node ---
node_modules/
npm-debug.log*

# --- obsidian per-vault state (created when you open the Store as a vault) ---
.obsidian/
store/.obsidian/

# --- misc ---
.DS_Store
Thumbs.db
